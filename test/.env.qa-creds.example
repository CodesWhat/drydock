# Optional credentials for the QA stack (test/qa-compose.yml).
# Copy this file to .env.qa-creds (gitignored) and fill in values to bypass
# the Docker Hub anonymous pull rate limit and use real GHCR tokens.
#
# Compose loads this file via `env_file:` with `required: false`, so a missing
# file is fine — CI runs without these creds.

# --- Docker Hub (hub.docker.com) ---
# Create a Personal Access Token at https://hub.docker.com/settings/security
# with at least public-repo read scope. Authenticated pulls have a much higher
# rate limit (200/6h instead of 100/6h, and tied to the account, not the IP).
DD_REGISTRY_HUB_PUBLIC_USERNAME=
DD_REGISTRY_HUB_PUBLIC_TOKEN=

# --- GHCR (ghcr.io) ---
# Create a classic GitHub PAT with `read:packages` scope at
# https://github.com/settings/tokens. Required to read private GHCR images;
# public images work without auth but the public/private namespace split in
# qa-compose.yml exercises the auth path.
DD_REGISTRY_GHCR_PRIVATE_USERNAME=
DD_REGISTRY_GHCR_PRIVATE_TOKEN=
