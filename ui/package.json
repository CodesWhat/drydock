{
  "name": "drydock-ui",
  "version": "1.5.1",
  "description": "Drydock dashboard — Vue 3 + Tailwind CSS 4 SPA",
  "repository": "CodesWhat/drydock",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "AGPL-3.0-only",
  "author": "CodesWhat",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "npm run icons && npm run fonts && vite build",
    "preview": "vite preview",
    "icons": "node scripts/extract-icons.mjs",
    "fonts": "node scripts/extract-fonts.mjs",
    "format": "biome format --write .",
    "lint:fix": "biome check --fix .",
    "lint": "biome check .",
    "test:security": "node ./node_modules/vitest/vitest.mjs run tests/security/*.spec.ts --maxWorkers=1 --fileParallelism=false",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:mutation": "stryker run",
    "knip": "knip"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "5.2.7",
    "iconify-icon": "3.0.2",
    "pinia": "3.0.4",
    "tailwindcss": "4.3.2",
    "vue": "3.5.39",
    "vue-draggable-plus": "0.6.1",
    "vue-i18n": "11.4.6",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@fontsource/comic-mono": "5.2.5",
    "@fontsource/commit-mono": "5.2.5",
    "@fontsource/inconsolata": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/source-code-pro": "5.2.7",
    "@iconify-json/fa6-solid": "1.2.4",
    "@iconify-json/heroicons": "1.2.3",
    "@iconify-json/iconoir": "1.2.11",
    "@iconify-json/lucide": "1.2.116",
    "@iconify-json/ph": "1.2.2",
    "@iconify-json/tabler": "1.2.35",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "25.9.4",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/test-utils": "2.4.11",
    "jsdom": "29.1.1",
    "knip": "6.24.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "fast-uri": "3.1.3",
    "js-cookie": "3.0.8",
    "minimatch": "10.2.5",
    "picomatch": "4.0.5",
    "postcss": "8.5.16",
    "qs": "6.15.3",
    "yaml": "2.9.0",
    "@babel/core": "7.29.7",
    "undici": "7.28.0"
  }
}
