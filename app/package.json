    "passport-http": "0.3.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "pushover-notifications": "1.2.3",
    "re2js": "2.8.5",
    "semver": "7.8.5",
    "set-value": "4.1.0",
    "sort-es": "1.7.18",
    "undici": "8.6.0",
    "uuid": "14.0.1",
    "ws": "8.21.0",
    "yaml": "2.9.0"
  },
  "overrides": {
    "axios": "1.18.1",
